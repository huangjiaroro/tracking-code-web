{
  "manifest_version": 3,
  "name": "UI Marker - 智能UI元素标记",
  "version": "1.0.0",
  "description": "自动识别并标记网页上的所有可操作UI元素",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "ws://127.0.0.1:*/*",
    "ws://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dom-utils/interactive-detector.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}